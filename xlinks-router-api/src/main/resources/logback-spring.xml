<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- Spring Boot default log patterns -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="APP_NAME" value="${spring.application.name:-xlinks-router-api}"/>
    <!--
      注意：这里必须用 logback 的属性替换语法 ${VAR:-default}
      不能用 ${VAR:default}，否则在 Windows 上会被解析成 "VAR:default_IS_UNDEFINED" 这种非法路径。
    -->
    <property name="LOG_HOME" value="${LOG_HOME:-logs}"/>

    <!-- Console output -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN:-%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Rolling file: archive daily, keep 30 days -->
    <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- daily rolling -->
            <fileNamePattern>${LOG_HOME}/archive/${APP_NAME}.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <!-- keep history -->
            <maxHistory>30</maxHistory>
            <!-- cap total size -->
            <totalSizeCap>5GB</totalSizeCap>
            <!-- create archive directory if possible -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- Hide MyBatis / MyBatis-Plus SQL logs -->
    <logger name="org.apache.ibatis" level="WARN"/>
    <logger name="com.baomidou.mybatisplus" level="WARN"/>
    <!-- optional: if you use mybatis logging under this package -->
    <logger name="java.sql" level="WARN"/>

    <!-- your app log level (can still be overridden by logging.level.* in application.yml) -->
    <logger name="site.xlinks.ai.router" level="DEBUG"/>
    <logger name="org.springframework" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ROLLING_FILE"/>
    </root>

</configuration>
